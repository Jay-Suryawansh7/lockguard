{
    "name": "lockguard",
    "version": "1.0.1",
    "description": "npm supply-chain security scanner — detect malicious postinstall hooks, CVE vulnerabilities, and unexpected lockfile changes",
    "license": "MIT",
    "author": "Jay Suryawanshi",
    "repository": {
        "type": "git",
        "url": "https://github.com/Jay-Suryawansh7/lockguard"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "type": "module",
    "bin": {
        "lockguard": "./dist/cli.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "action"
    ],
    "scripts": {
        "build": "tsc",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "lint": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "commander": "^12.0.0",
        "chalk": "^5.3.0"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "^20.0.0",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "typescript": "^5.4.0"
    },
    "keywords": [
        "npm",
        "security",
        "supply-chain",
        "postinstall",
        "cve",
        "lockfile",
        "audit",
        "vulnerability"
    ]
}
